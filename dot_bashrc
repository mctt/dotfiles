export PATH="/root/bin:$PATH"

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# History settings
HISTSIZE=10000
HISTFILESIZE=20000
HISTCONTROL=ignoredups:erasedups
shopt -s histappend
PROMPT_COMMAND="history -a; history -c; history -r; $PROMPT_COMMAND"

# Auto-cd when typing just a directory name
shopt -s autocd

# Better tab completion
shopt -s cdspell
shopt -s dirspell
shopt -s nocaseglob

# Aliases
alias la='ls -la'
alias ll='ls -l'
alias ..='cd ..'
alias ...='cd ../..'

# Auto-attach to screen session
#if [ -z "$STY" ]; then
#    screen -xRR
#fi
# breaks chezmoi subshell. 

# Only auto-attach if we are a login shell and not already in a multiplexer
if [ -z "$STY" ] && [ -z "$TMUX" ] && shopt -q login_shell; then
    screen -xRR
fi
# Display shell nesting to detect runaway subshells
# echo $SHLVL
echo "# Display shell nesting level on login to detect runaway subshells"
echo "SHLVL: $SHLVL"

# Prompt (simple and clean)
#PS1='\u@\h:\w\$ '
#PS1='@unas :\w\$ '
# this keeps an eye in thr subs sessions
# PS1='[$SHLVL] \u@\h:\w\$ '
PS1='$SHLVL \h:\w\$ '


alias python=python3.11

[ -f ~/.fzf.bash ] && source ~/.fzf.bash

alias na.='nano $(fzf)'

# fzf file/dir utilities
fcp() {
  local src dst
  src=$(find . -type f | fzf --prompt="Source file: " --preview="ls -lh {}") || return
  dst=$(find . -type d | fzf --prompt="Dest dir: "    --preview="ls {}") || return
  cp -v "$src" "$dst"
}

frs() {
  local src dst
  src=$(find . -type f | fzf --prompt="Source file: " --preview="ls -lh {}") || return
  dst=$(find . -type d | fzf --prompt="Dest dir: "    --preview="ls {}") || return
  rsync -avh --progress "$src" "$dst"
}

frsd() {
  local src dst
  src=$(find . -type d | fzf --prompt="Source dir: " --preview="ls {}") || return
  dst=$(find . -type d | fzf --prompt="Dest dir: "   --preview="ls {}") || return
  echo "Rsync: $src → $dst"
  read -p "Continue? [y/N] " confirm
  [[ "$confirm" == [yY] ]] && rsync -avh --progress "$src/" "$dst"
}

case "$(hostname)" in
  unas) [ -f ~/.bashrc.unas ] && source ~/.bashrc.unas ;;
  qnas) [ -f ~/.bashrc.qnas ] && source ~/.bashrc.qnas ;;
esac

# Chezmoi bash completion
eval "$(chezmoi completion bash)"

# pkg install bash-completion
# Bash completion
[[ -f /usr/local/share/bash-completion/bash_completion.sh ]] && \
  source /usr/local/share/bash-completion/bash_completion.sh

export EDITOR=nano
