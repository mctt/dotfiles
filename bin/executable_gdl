#!/data/data/com.termux/files/usr/bin/bash
# gdl.sh -- gallery-dl wrapper for Termux / Reddit
# Usage: gdl.sh [OPTIONS] [URL...]
# Switches: -f FILE  -a FILE  -b FILE  (URL list files)

# https://claude.ai/share/675440a5-96dd-4110-9bb3-4d7388ed5616

set -euo pipefail

# =============================================================================
# Config
# =============================================================================
BASE_DIR="/data/data/com.termux/files/home/storage/downloads/synco"
ARCHIVE_FILE="$BASE_DIR/.download_archive"
GALLERY_DL="gallery-dl"

# =============================================================================
# Colour helpers
# =============================================================================
red()    { printf '\033[1;31m%s\033[0m\n' "$*"; }
yellow() { printf '\033[1;33m%s\033[0m\n' "$*"; }
green()  { printf '\033[1;32m%s\033[0m\n' "$*"; }
cyan()   { printf '\033[1;36m%s\033[0m\n' "$*"; }
bold()   { printf '\033[1m%s\033[0m\n'   "$*"; }

# =============================================================================
# Ensure gallery-dl is available
# =============================================================================
ensure_gallery_dl() {
    if command -v gallery-dl &>/dev/null; then return; fi
    yellow "gallery-dl not found -- attempting install via pip..."
    if ! command -v pip &>/dev/null && ! command -v pip3 &>/dev/null; then
        yellow "pip not found -- installing python via pkg..."
        pkg install -y python
    fi
    pip install gallery-dl 2>/dev/null || pip3 install gallery-dl
    if ! command -v gallery-dl &>/dev/null; then
        red "ERROR: gallery-dl install failed. Run: pip install gallery-dl"
        exit 1
    fi
    green "gallery-dl installed successfully."
}

# =============================================================================
# Extract Reddit slug from URL
#   reddit.com/user/NAME         -> NAME
#   reddit.com/u/NAME            -> NAME
#   reddit.com/r/SUB/s/ID        -> r_SUB_ID   (share links)
#   reddit.com/r/SUB/comments/ID -> r_SUB_ID
#   reddit.com/r/SUB             -> r_SUB
# =============================================================================
extract_reddit_slug() {
    local url="$1"
    if [[ "$url" =~ reddit\.com/(user|u)/([^/?#]+) ]]; then
        echo "${BASH_REMATCH[2]}"; return
    fi
    if [[ "$url" =~ reddit\.com/r/([^/?#]+)/comments/([^/?#]+) ]]; then
        echo "r_${BASH_REMATCH[1]}_${BASH_REMATCH[2]}"; return
    fi
    if [[ "$url" =~ reddit\.com/r/([^/?#]+)/s/([^/?#]+) ]]; then
        echo "r_${BASH_REMATCH[1]}_${BASH_REMATCH[2]}"; return
    fi
    if [[ "$url" =~ reddit\.com/r/([^/?#]+) ]]; then
        echo "r_${BASH_REMATCH[1]}"; return
    fi
    echo "$url" | sed 's|https\?://||; s|[/?&#]|_|g; s|__*|_|g; s|_$||'
}

resolve_dest() {
    echo "$BASE_DIR/$(extract_reddit_slug "$1")"
}

# =============================================================================
# Duplicate pre-check
# gallery-dl's --download-archive stores content ID hashes so previously
# downloaded files are skipped automatically. This prompt fires when the
# destination folder already has content.
# =============================================================================
check_archive_exists() {
    local dest="$1"
    if [[ -f "$ARCHIVE_FILE" ]] && [[ -d "$dest" ]] && \
       [[ -n "$(ls -A "$dest" 2>/dev/null)" ]]; then
        yellow "WARNING: '$dest' already exists."
        yellow "         Known files will be skipped automatically."
        printf  "Continue? [Y/n] "
        read -r ans
        case "${ans,,}" in
            n|no) echo "Aborted."; exit 0 ;;
        esac
    fi
}

# =============================================================================
# Core download
# =============================================================================
download_url() {
    local url="$1"
    local dest
    dest="$(resolve_dest "$url")"

    echo "-------------------------------------------"
    bold "URL      : $url"
    bold "Dest     : $dest"
    echo "-------------------------------------------"

    check_archive_exists "$dest"
    mkdir -p "$dest"

    local gdl_args=(
        "$GALLERY_DL"
        --directory "$dest"
        --download-archive "$ARCHIVE_FILE"
        --retries 4
        --http-timeout 30
        -o "reddit.videos=ytdl"
        -o "reddit.comments=false"
        -f "{id} {title:R?/_/R:/_/R*/_/R|/_/} {num:>02}.{extension}"
        "$url"
    )

    echo "Running: ${gdl_args[*]}"
    local rc=0
    "${gdl_args[@]}" || rc=$?

    if [[ $rc -eq 0 ]]; then
        green "Done: $url  ->  $dest"
    else
        red "gallery-dl exited with status $rc for: $url"
    fi
    return $rc
}

# =============================================================================
# Process a URL list file
# =============================================================================
process_file() {
    local file="$1"
    if [[ ! -f "$file" ]]; then
        red "ERROR: file not found: $file"; return 1
    fi
    local count=0 errors=0
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" || "$line" == \#* ]] && continue
        local rc=0
        download_url "$line" || rc=$?
        if [[ $rc -eq 0 ]]; then count=$(( count + 1 ))
        else                       errors=$(( errors + 1 ))
        fi
    done < "$file"
    bold "File '$file': $count ok, $errors errors"
}

# =============================================================================
# Download all posts from a Reddit user
# =============================================================================
download_user() {
    local username="$1"
    username="${username#u/}"; username="${username#/u/}"
    yellow "Fetching all submissions for u/$username..."
    download_url "https://www.reddit.com/user/${username}/submitted/"
}

# =============================================================================
# Usage
# =============================================================================
usage() {
    cat <<EOF
gdl.sh -- gallery-dl wrapper for Termux / Reddit

Usage:
  gdl.sh [URL...]          Download one or more URLs
  gdl.sh -f FILE           Download URLs from FILE (skip blanks / # lines)
  gdl.sh -a FILE           Alias for -f
  gdl.sh -b FILE           Alias for -f
  gdl.sh -u USERNAME       Download all posts from a Reddit user profile
  gdl.sh -h                Show this help

Files go to:
  $BASE_DIR/<reddit_slug>/

Download archive: $ARCHIVE_FILE

Examples:
  gdl.sh https://www.reddit.com/user/gallowboob/submitted/
  gdl.sh -u gallowboob
  gdl.sh -f my_urls.txt
  gdl.sh https://www.reddit.com/r/3Dprinting/s/S2Mk3lyC58
EOF
}

# =============================================================================
# Main
# =============================================================================
ensure_gallery_dl
mkdir -p "$BASE_DIR"

if [[ $# -eq 0 ]]; then usage; exit 0; fi

URLS=()
FILES=()
USERS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage; exit 0 ;;
        -f|-a|-b)
            shift
            [[ $# -eq 0 ]] && { red "ERROR: flag requires a FILE argument"; exit 1; }
            FILES+=("$1") ;;
        -u|--user)
            shift
            [[ $# -eq 0 ]] && { red "ERROR: -u requires a USERNAME"; exit 1; }
            USERS+=("$1") ;;
        *) URLS+=("$1") ;;
    esac
    shift
done

_had_work=0

if [[ ${#USERS[@]} -gt 0 ]]; then
    _had_work=1
    for u in "${USERS[@]}"; do [[ -n "$u" ]] && download_user "$u"; done
fi

if [[ ${#FILES[@]} -gt 0 ]]; then
    _had_work=1
    for f in "${FILES[@]}"; do [[ -n "$f" ]] && process_file "$f"; done
fi

if [[ ${#URLS[@]} -gt 0 ]]; then
    _had_work=1
    for url in "${URLS[@]}"; do [[ -n "$url" ]] && download_url "$url"; done
fi

[[ $_had_work -eq 0 ]] && usage
